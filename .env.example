# Public site
NEXT_PUBLIC_PROJECT_NAME="Proof of Conviction"
NEXT_PUBLIC_SOURCE_SYMBOL="CONVICTION"
NEXT_PUBLIC_REWARD_SYMBOL="SOL"
NEXT_PUBLIC_CONVICTION_TOKEN_MINT=
NEXT_PUBLIC_CONVICTION_X_URL=
NEXT_PUBLIC_CONVICTION_COMMUNITY_URL=
NEXT_PUBLIC_DEXSCREENER_URL=
NEXT_PUBLIC_PUMP_URL=
NEXT_PUBLIC_BUY_URL=
NEXT_PUBLIC_REWARD_INTERVAL="5 minutes"
NEXT_PUBLIC_MINIMUM_ELIGIBLE_BALANCE=500000
NEXT_PUBLIC_MAX_HOLDER_PCT=4
NEXT_PUBLIC_SITE_URL="https://proofofconviction.fun"

# Site dashboard
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE=

# Worker / Railway
REWARD_MODE=sol
HELIUS_RPC_URL=
SOURCE_TOKEN_MINT=
TREASURY_WALLET_SECRET=

# Fail closed. Keep the worker parked until a fresh treasury and a dry run are reviewed.
CLAIM_ENABLED=false
BUY_ENABLED=false
AIRDROP_ENABLED=false
EMERGENCY_STOP=true

# Five-minute snapshots and Proof of Conviction eligibility
EPOCH_MINUTES=5
ELIGIBILITY_MIN=500000
MAX_WALLETS_PER_EPOCH=100
EXCLUDE_WALLETS=

# Holder weighting is hold-time only. No rank or wallet-size multipliers.

# Exclude wallets above 4% from rewards.
ENFORCE_MAX_HOLDER_PCT=true
MAX_HOLDER_PCT=4

# SOL reward epochs distribute the configured share of newly claimed SOL.
AIRDROP_REWARD_BPS=10000
SOL_AIRDROP_BALANCE_BPS=7500
MIN_SOL_RESERVE=0.3
AIRDROP_SOL_RESERVE=0.05
AIRDROP_BATCH_SIZE=4
MIN_SOL_REWARD_LAMPORTS_TO_AIRDROP=5000
PRIORITY_FEE_SOL=0.000001
