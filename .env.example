# Live gates. Keep false until ready.
CLAIM_ENABLED=false
BUY_ENABLED=false
AIRDROP_ENABLED=false
LONG_SOL_ENABLED=false

# Reward logic
EPOCH_MINUTES=5
ELIGIBILITY_MIN=250000
MAX_WALLETS_PER_EPOCH=150
MAX_HOLDER_PCT=5
