# Shared public site labels
NEXT_PUBLIC_PROJECT_NAME="HyperHood"
NEXT_PUBLIC_SOURCE_SYMBOL=HHOOD
NEXT_PUBLIC_REWARD_SYMBOL=HHOOD
NEXT_PUBLIC_SOURCE_TOKEN_MINT=<HYPERHOOD_TOKEN_MINT>
NEXT_PUBLIC_CA=<HYPERHOOD_TOKEN_MINT>
NEXT_PUBLIC_X_URL=https://x.com/HyperHood_
NEXT_PUBLIC_BUY_URL=<HYPERHOOD_BUY_URL>
NEXT_PUBLIC_DEXSCREENER_URL=<HYPERHOOD_DEXSCREENER_URL>
# Site API reads Supabase for dashboard stats.
# Use anon only if RLS policies allow read access to dashboard tables.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional server-only Vercel env. Preferred for dashboard API reads.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE=
BAGHOLDER_WALLET_PUBLIC_KEY=

# Worker / Railway
REWARD_MODE=token
HELIUS_RPC_URL=
SOURCE_TOKEN_MINT=<HYPERHOOD_TOKEN_MINT>
REWARD_TOKEN_MINT=
TREASURY_WALLET_SECRET=

# Live gates. Keep false until ready.
CLAIM_ENABLED=false
BUY_ENABLED=false
AIRDROP_ENABLED=false

# HyperHood revenue distribution logic: 50% HOOD drops, 50% HH/HOOD LP reinforcement.
EPOCH_MINUTES=15
ELIGIBILITY_MIN=1000000
MAX_WALLETS_PER_EPOCH=75
MAX_HOLDER_PCT=5
EXCLUDE_WALLETS=

# Claimed SOL is used for HOOD buys and HH/HOOD LP reinforcement.
SWAP_BALANCE_BPS=10000
SWAP_SLIPPAGE_BPS=300
INDEX_AIRDROP_BPS=0
SIDE_WALLET_BPS=0
SIDE_WALLET_PUBLIC_KEY=

# Send safety
MIN_SOL_RESERVE=0.3
AIRDROP_SOL_RESERVE=0.05
AIRDROP_BATCH_SIZE=4
AIRDROP_REWARD_BPS=10000
PRIORITY_FEE_SOL=0.000001
MIN_REWARD_RAW_TO_AIRDROP=1
