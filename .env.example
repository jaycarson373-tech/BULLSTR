# Site dashboard
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE=

# Worker / Railway
# Canonical Solana mainnet USDC mint, verified against Circle's official contract list.
REWARD_MODE=token
REWARD_TOKEN_MINT="EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v"
REWARD_TOKEN_SYMBOL="USDC"
HELIUS_RPC_URL=
SOURCE_TOKEN_MINT=
TREASURY_WALLET_SECRET=

# Fail closed. Keep the worker parked until a fresh treasury and a dry run are reviewed.
CLAIM_ENABLED=false
BUY_ENABLED=false
AIRDROP_ENABLED=false
EMERGENCY_STOP=true

# Five-minute snapshots and holder eligibility
EPOCH_MINUTES=5
ELIGIBILITY_MIN=1000000
MAX_WALLETS_PER_EPOCH=100
EXCLUDE_WALLETS=

# Holder weighting. 10000 bps = 1x.
TOP_10_MULTIPLIER_BPS=20000
TOP_50_MULTIPLIER_BPS=15000
TOP_100_MULTIPLIER_BPS=12500

# Legacy whale exclusion remains disabled unless explicitly approved.
ENFORCE_MAX_HOLDER_PCT=false
MAX_HOLDER_PCT=5

# Claimed SOL buys USDC; only USDC acquired in the current epoch is distributable.
AIRDROP_REWARD_BPS=10000
SWAP_BALANCE_BPS=10000
SWAP_SLIPPAGE_BPS=300
MIN_SOL_RESERVE=0.3
AIRDROP_SOL_RESERVE=0.05
AIRDROP_BATCH_SIZE=4
MIN_REWARD_RAW_TO_AIRDROP=1
PRIORITY_FEE_SOL=0.000001
